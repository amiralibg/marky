{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marky",
  "version": "0.0.4",
  "identifier": "com.amiralibg.marky",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Marky - Markdown Editor",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "devtools": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://github.com/amiralibg/marky/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1MUNENzlDODI4RThBM0QKUldROWlvNkNuTmNjcGJCZmxncmcyMG1Ocjk3UEQvOGpJWEdGYjRkRmc3dWhDaVBLTFlrZFJnZloK"
    },
    "shell": {
      "open": true
    }
  }
}
